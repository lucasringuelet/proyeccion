# Clave única compartida para acceder a la app.
# Cambiá esto antes de hacer deploy.
APP_PASSWORD=changeme

# String aleatorio para firmar las cookies de sesión.
# Generá uno con: openssl rand -hex 32
SESSION_SECRET=replace-with-32-byte-hex-from-openssl-rand

# Puerto donde escucha el backend
PORT=3001

# Directorio donde se guarda app.db y los .xls subidos
DATA_DIR=./data

# Tamaño máximo de archivo subido en MB
MAX_UPLOAD_MB=20

# Origen permitido del frontend en desarrollo (CORS).
# En producción el backend sirve el frontend desde el mismo origen, así que
# este valor solo se usa cuando NODE_ENV !== production.
DEV_FRONTEND_ORIGIN=http://localhost:5173

# Forzar el flag Secure en la cookie de sesión.
# - true  → cookie solo se manda por HTTPS (requerido en prod sobre HTTPS).
# - false → cookie también se manda por HTTP (necesario si exponés la app por
#           HTTP plano dentro de la red interna, sin reverse proxy con TLS).
# - sin setear → default es true cuando NODE_ENV=production, false en dev.
# SECURE_COOKIES=false

# URL del archivo SQLite (Prisma).
# El path es relativo a `prisma/schema.prisma`, así que `../data/app.db`
# apunta a `backend/data/app.db`.
DATABASE_URL="file:../data/app.db"
